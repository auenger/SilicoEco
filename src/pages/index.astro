---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Hero from "../components/Hero.astro";
import WorkLoop from "../components/WorkLoop.astro";
import KernelSection from "../components/KernelSection.astro";
import OrganizationSection from "../components/OrganizationSection.astro";
import KnowledgeSection from "../components/KnowledgeSection.astro";
import SurfacesSection from "../components/SurfacesSection.astro";
import GovernanceSection from "../components/GovernanceSection.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout>
  <SiteHeader />
  <main>
    <Hero />
    <section class="manifesto section">
      <div class="container manifesto-grid">
        <p data-reveal>不是聊天机器人<br />不是 Agent 工具箱<br />不是新的 IM</p>
        <h2 data-reveal>传统操作系统管理计算资源。SilicoEco 管理<span>意图、任务、角色、上下文、能力、决策与组织知识</span>。</h2>
      </div>
    </section>
    <WorkLoop />
    <KernelSection />
    <OrganizationSection />
    <KnowledgeSection />
    <SurfacesSection />
    <GovernanceSection />
  </main>
  <SiteFooter />
</BaseLayout>
