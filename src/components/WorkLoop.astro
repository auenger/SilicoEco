---
const steps = [
  ["业务目标", "明确流程希望改变的结果"],
  ["SOP 拆解", "转化为可执行的标准步骤"],
  ["责任分配", "交给合适的人类或 AI 员工"],
  ["协作执行", "共享状态、上下文和产物"],
  ["人工决策", "关键节点由责任人判断"],
  ["持续改进", "把经验写回 SOP 与知识库"]
];
---

<section class="work-loop section" id="loop">
  <div class="container">
    <div class="section-copy compact-copy" data-reveal>
      <h2>让业务 SOP 成为 AI 员工的工作轨道。</h2>
      <p>流程不再停留在文档里。它会转化为任务、责任、检查点、证据和可以持续改进的组织能力。</p>
    </div>
    <div class="loop-stage" data-reveal>
      <div class="loop-progress" aria-hidden="true">
        {steps.map(() => <i></i>)}
      </div>
      <div class="loop-items">
        {steps.map(([name, detail]) => (
          <article class="loop-item">
            <strong>{name}</strong>
            <p>{detail}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
