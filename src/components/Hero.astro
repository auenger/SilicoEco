---
import HeroParticleField from "./HeroParticleField.astro";
---

<section class="hero" id="top" data-hero>
  <HeroParticleField />

  <div class="hero-shell container">
    <div class="hero-content">
      <div class="hero-name hero-signature" data-reveal>
        <a href="https://siliroot.com/" target="_blank" rel="noreferrer">A SiliRoot Product</a>
        <i aria-hidden="true"></i>
        <span>The Work OS for Human + Agent</span>
      </div>
      <h1 data-reveal>让人类员工与 AI 员工，<span>在同一个组织中协作。</span></h1>
      <p class="hero-subtitle" data-reveal>连接业务 SOP、任务、知识和权限，让每一种 Agent 产品形态都能成为组织成员。</p>
      <div class="hero-actions" data-reveal>
        <a class="button button-primary" href="#ecosystem">查看生态</a>
      </div>
    </div>

    <div class="hero-ecosystem" data-reveal aria-label="SilicoEco 连接不同 Agent 产品形态与工作入口">
      <div class="ecosystem-core"><strong>SilicoEco</strong><span>Task OS</span></div>
      <div class="ecosystem-node"><strong>AI 员工平台</strong><span>数字岗位与持续工作</span></div>
      <div class="ecosystem-node"><strong>桌面与 Web App</strong><span>个人和团队工作空间</span></div>
      <div class="ecosystem-node"><strong>Agent Runtime</strong><span>二进制、服务与 CLI</span></div>
      <div class="ecosystem-node"><strong>Browser Agent</strong><span>真实业务执行环境</span></div>
      <div class="ecosystem-node"><strong>MCP + Skills</strong><span>能力与操作协议</span></div>
      <div class="ecosystem-node"><strong>IM + CLI</strong><span>沟通与协作入口</span></div>
      <div class="ecosystem-wire" aria-hidden="true"></div>
    </div>
  </div>
</section>
