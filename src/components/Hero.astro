---
import HeroParticleField from "./HeroParticleField.astro";
---

<section class="hero" id="top" data-hero>
  <HeroParticleField />

  <div class="hero-shell container">
    <div class="hero-content">
      <div class="hero-name hero-signature" data-reveal>
        <a href="https://siliroot.com/" target="_blank" rel="noreferrer">A SiliRoot Product</a>
        <i aria-hidden="true"></i>
        <span>The Work OS for Human + Agent</span>
      </div>
      <h1 data-reveal>让每一项工作，<span>在人与 Agent 之间持续向前。</span></h1>
      <p class="hero-subtitle" data-reveal>统一任务、上下文、执行与治理，让不同入口和 Agent 围绕同一个工作目标协作。</p>
      <div class="hero-actions" data-reveal>
        <a class="button button-primary" href="#loop">理解工作闭环</a>
      </div>
    </div>

    <div class="hero-ecosystem" data-reveal aria-label="SilicoEco 以 Work 为中心连接工作所需的核心对象">
      <div class="ecosystem-core"><strong>WORK</strong><span>SilicoEco Work OS</span></div>
      <div class="ecosystem-node"><strong>Task</strong><span>目标、状态与完成标准</span></div>
      <div class="ecosystem-node"><strong>Context</strong><span>知识、历史与当前环境</span></div>
      <div class="ecosystem-node"><strong>Actor</strong><span>人、Agent 与外部系统</span></div>
      <div class="ecosystem-node"><strong>Policy</strong><span>授权、审批与责任边界</span></div>
      <div class="ecosystem-node"><strong>Artifact</strong><span>产物、证据与决策记录</span></div>
      <div class="ecosystem-node"><strong>Surface</strong><span>桌面、Web、IM 与 CLI</span></div>
      <div class="ecosystem-wire" aria-hidden="true"></div>
    </div>
  </div>
</section>
