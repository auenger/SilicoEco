---
const roles = [
  ["人类员工", "目标、判断与最终责任"],
  ["AI 员工", "执行、协作与持续响应"],
  ["主管 Agent", "分派、协调与升级处理"],
  ["审查 Agent", "验证边界、质量与证据"]
];
---

<section class="organization-section section" id="ai-workforce">
  <div class="container organization-grid">
    <div class="organization-copy" data-reveal>
      <h2>OS 管理每一位 AI 员工的职责。</h2>
      <p>每个 Agent 都有岗位、工作职责、业务 SOP、能力范围、数据边界和人类负责人。模型和运行位置可以更换，组织身份保持连续。</p>
      <div class="identity-rule">
        <span>AI Employee</span>
        <strong>岗位 + 职责 + SOP + 权限 + 责任人</strong>
      </div>
    </div>

    <div class="team-orbit" data-reveal aria-label="人类员工与不同职责的 AI 员工组成混合团队">
      <div class="human-node">
        <span class="person-glyph" aria-hidden="true"><i></i></span>
        <strong>组织目标</strong>
        <small>统一任务与责任关系</small>
      </div>
      {roles.map(([name, detail], index) => (
        <article class={`role-node role-${index + 1}`}>
          <span class="agent-glyph" aria-hidden="true"><i></i></span>
          <strong>{name}</strong>
          <small>{detail}</small>
        </article>
      ))}
      <svg viewBox="0 0 700 700" aria-hidden="true">
        <circle cx="350" cy="350" r="242"></circle>
        <circle cx="350" cy="350" r="126"></circle>
        <path class="focus" d="M350 108V224M350 476v116M108 350h116M476 350h116"></path>
      </svg>
    </div>
  </div>
</section>
