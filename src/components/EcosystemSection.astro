---
const ecosystems = [
  ["统一工作模型", "所有入口围绕 Task、Run、Artifact、Evidence 和 Decision 交换状态。"],
  ["业务 SOP", "把企业流程变成可分配、可执行、可检查、可持续改进的任务轨道。"],
  ["人和 Agent", "工作可以由人、Agent、自动化流程或外部系统执行和交接。"],
  ["应用与运行时", "桌面、Web、浏览器、服务和 CLI 共享上下文与工作状态。"],
  ["MCP + Skills", "通过开放协议连接外部 Agent 与应用，同时保留权限、审批和审计边界。"],
  ["协作渠道", "IM、App 和终端都能发起和推进工作，状态最终回到统一 Task。"]
];
---

<section class="ecosystem-section section" id="ecosystem">
  <div class="container ecosystem-heading" data-reveal>
    <h2>生态可以来自不同地方，<br />工作运行在同一套系统里。</h2>
    <p>不同 Agent、应用和运行环境接入 SilicoEco 后，围绕同一个 Task 共享上下文、状态、产物与治理规则。</p>
  </div>
  <div class="container ecosystem-grid" data-reveal>
    {ecosystems.map(([name, body], index) => (
      <article class={`ecosystem-capability capability-${index + 1}`}>
        <h3>{name}</h3>
        <p>{body}</p>
      </article>
    ))}
  </div>
</section>
