---
const surfaces = [
  ["AI 员工平台", "数字员工进入岗位体系，接受职责、SOP、任务分工、权限和审计管理。"],
  ["桌面与 Web", "个人工作台与团队空间共享项目、身份、任务和组织知识。"],
  ["Agent Runtime", "本地进程、服务、二进制与 CLI 可以承接长任务和自动化工作。"],
  ["Browser Agent", "Agent 在真实业务系统中行动，人类可以观察、审批和接管。"],
  ["MCP + Skills", "组织能力通过标准协议开放给内部和外部 Agent 安全调用。"],
  ["IM + CLI", "沟通渠道可以创建、更新和接收任务，但状态始终回到统一平台。"]
];
---

<section class="surfaces-section section" id="surfaces">
  <div class="container">
    <div class="section-copy compact-copy" data-reveal>
      <h2>生态可以不同，工作始终相通。</h2>
      <p>平台不限定用户从哪里开始。所有入口共享 Task、Actor、Context、Policy 与 Knowledge。</p>
    </div>
    <div class="surface-track" data-reveal>
      {surfaces.map(([name, body]) => (
        <article class="surface-item">
          <h3>{name}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
